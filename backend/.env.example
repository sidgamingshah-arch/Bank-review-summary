# Copy to .env and fill in. Only the variables for your chosen provider are needed.

# --- LLM provider selection ---
# anthropic | bedrock | vertex
LLM_PROVIDER=anthropic
# Claude model id (bare for anthropic/vertex; provider.py adds the "anthropic." prefix on Bedrock)
MODEL=claude-opus-4-8

# --- Anthropic API (direct) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AWS Bedrock (if LLM_PROVIDER=bedrock) ---
# Uses the standard AWS credential chain; only the region is read here.
AWS_REGION=us-east-1

# --- Google Vertex AI (if LLM_PROVIDER=vertex) ---
VERTEX_PROJECT_ID=
VERTEX_REGION=global

# --- App behaviour ---
PLACEHOLDER_TEXT=[To be entered by L1]
MAX_PDF_MB=28
MAX_TOKENS=16000
DATA_DIR=./data
