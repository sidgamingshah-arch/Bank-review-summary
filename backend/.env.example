# ─────────────────────────────────────────────────────────────────────────────
# ASM Review Note Generator — configuration & API keys
#
# 1. Copy this file to ".env" in the backend/ folder:    cp .env.example .env
# 2. Paste your key(s) below.
#
# This is the ONLY file you edit to add keys. It is git-ignored, so secrets are
# never committed. On startup the app loads it for every provider (Anthropic,
# AWS for Bedrock, Google for Vertex). You can instead name it "secrets.env",
# or point the ASM_ENV_FILE environment variable at any path.
# ─────────────────────────────────────────────────────────────────────────────

# Which Claude hosting to use:  anthropic | bedrock | vertex
LLM_PROVIDER=anthropic

# Claude model id (bare for anthropic/vertex; the "anthropic." prefix is added
# automatically for Bedrock).
MODEL=claude-opus-4-8


# === Anthropic API (direct) — the usual setup ===========================
# Create a key at https://console.anthropic.com/ and paste it here:
ANTHROPIC_API_KEY=
# Optional: custom endpoint / gateway URL (leave blank for the default).
ANTHROPIC_BASE_URL=


# === AWS Bedrock (only if LLM_PROVIDER=bedrock) =========================
# Uses the standard AWS credential chain. Set the region, then either put AWS
# keys here or rely on ~/.aws / an instance role.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=


# === Google Vertex AI (only if LLM_PROVIDER=vertex) =====================
VERTEX_PROJECT_ID=
VERTEX_REGION=global
# Path to a service-account JSON for Google ADC:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# === App behaviour (optional; defaults shown) ===========================
PLACEHOLDER_TEXT=[To be entered by L1]
MAX_PDF_MB=28
MAX_TOKENS=16000
DATA_DIR=./data
