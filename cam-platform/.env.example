# Copy to .env (git-ignored). Secrets are env/vault-provided only — never
# committed, never logged, never visible to the front-end (NFR-06).

# HS256 signing secret for dev tokens. Production: bank IdP (OIDC) + vault.
CAM_JWT_SECRET=change-me

# LLM provider for the genai-gateway: mock (offline, default) | anthropic
CAM_LLM_PROVIDER=mock
CAM_GENAI_MODEL=claude-opus-4-8
# Required only when CAM_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Demo login password for seeded users (dev IdP stub only)
CAM_DEMO_PASSWORD=Demo#2026
