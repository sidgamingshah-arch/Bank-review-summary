# Copy to .env (git-ignored). Secrets are env/vault-provided only — never
# committed, never logged, never visible to the front-end (NFR-06).

# HS256 signing secret for dev tokens. Production: bank IdP (OIDC) + vault.
CAM_JWT_SECRET=change-me

# ---- LLM egress (genai-gateway) -------------------------------------------
# Provider: mock (offline, default) | anthropic | openai
CAM_LLM_PROVIDER=mock
CAM_GENAI_MODEL=claude-opus-4-8
CAM_GENAI_MAX_TOKENS=2000

# anthropic provider: key is read directly by the Anthropic SDK
ANTHROPIC_API_KEY=

# openai provider — any OpenAI-compatible /v1/chat/completions endpoint
# (vLLM, LiteLLM, Azure OpenAI, Ollama, a bank-hosted gateway). Base URL must
# include the version prefix; "/chat/completions" is appended.
CAM_GENAI_BASE_URL=
# Name of the env var that holds the key (the value is read at start, never
# logged). Set that var too, e.g. CAM_GENAI_API_KEY=sk-...
CAM_GENAI_API_KEY_ENV=CAM_GENAI_API_KEY
CAM_GENAI_API_KEY=
# Authorization header scheme (default "Bearer"; set "" for a raw key)
CAM_GENAI_AUTH_SCHEME=Bearer
CAM_GENAI_TEMPERATURE=0.0
CAM_GENAI_TIMEOUT_SECONDS=120

# ---- External grounding connectors (client-provided, integrated) ----------
# On/off is a runtime setting (Masters > Settings); these are the endpoint
# URLs (deployment config). Enabled + empty URL -> a clearly-marked mock feed.
CAM_CONNECTOR_NEWS_URL=
CAM_CONNECTOR_SEARCH_URL=
CAM_CONNECTOR_API_KEY_ENV=CAM_CONNECTOR_API_KEY
CAM_CONNECTOR_API_KEY=

# Demo login password for seeded users (dev IdP stub only)
CAM_DEMO_PASSWORD=Demo#2026
